{
  "name": "mbjp-app",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "check": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "safe-export": "bash scripts/safe-export.sh",
    "lock:sync": "npm install --package-lock-only",
    "verify:clean": "npm run check && npm run build",
    "qa": "bash scripts/verify-project.sh",
    "qa:archive": "bash scripts/check-safe-archive.sh",
    "verify:production": "bash scripts/verify-production-readiness.sh",
    "verify:android": "bash scripts/verify-android-twa.sh",
    "clean:cache": "bash scripts/clear-local-cache.sh"
  },
  "dependencies": {
    "@faker-js/faker": "^10.3.0",
    "@supabase/supabase-js": "^2.106.0",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/match-sorter-utils": "latest",
    "@tanstack/react-form": "latest",
    "@tanstack/react-query": "latest",
    "@tanstack/react-router": "1.170.11",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "1.168.20",
    "@tanstack/react-table": "latest",
    "@tanstack/router-plugin": "1.168.14",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "html-to-image": "^1.11.13",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.577.0",
    "nitro": "3.0.260603-beta",
    "qrcode": "^1.5.4",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3.0.2",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.3.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "latest",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-query-devtools": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.10.2",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "6.0.2",
    "jsdom": "^28.1.0",
    "supabase": "^2.100.0",
    "typescript": "^6.0.2",
    "vite": "8.0.16",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}
